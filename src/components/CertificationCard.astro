---
import { Image } from "astro:assets";

interface Props {
  title: string;
  issuer: string;
  imageSrc?: ImageMetadata;
  href?: string;
  class?: string;
}

const { title, issuer, imageSrc, href = "#", class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group glass-card rounded-2xl p-5 flex items-center gap-4 transition-all duration-300 hover:shadow-lg hover:-translate-y-1",
    className,
  ]}
>
  {
    imageSrc && (
      <div class="w-14 h-14 rounded-xl overflow-hidden shrink-0">
        <Image
          src={imageSrc}
          alt={title}
          width={56}
          height={56}
          class="w-full h-full object-cover"
        />
      </div>
    )
  }
  <div class="min-w-0">
    <h4
      class="text-sm font-bold text-secondary group-hover:text-primary transition-colors truncate"
    >
      {title}
    </h4>
    <p class="text-xs text-secondary/50 mt-0.5">{issuer}</p>
  </div>
  <svg
    class="w-4 h-4 text-secondary/30 group-hover:text-primary shrink-0 ml-auto transition-all duration-300 group-hover:translate-x-1"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
  </svg>
</a>
