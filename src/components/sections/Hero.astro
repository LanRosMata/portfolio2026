---
import StatItem from "../ui/StatItem.astro";

const stats = [
  { value: "+2", label: "Años de experiencia" },
  { value: "+20", label: "Proyectos realizados" },
  { value: "100%", label: "Compromiso" },
  { value: "100%", label: "Dedicación" },
];
---

<section id="inicio" class="relative bg-secondary overflow-hidden">
  <!-- Hero Content -->
  <div
    class="min-h-screen flex flex-col justify-center px-6 lg:px-10 max-w-[1400px] mx-auto pt-24 pb-16"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Text -->
      <div class="lg:col-span-7 space-y-8">
        <div
          class="hero-badge inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span
            class="text-xs font-medium text-white/50 uppercase tracking-widest"
            >Disponible para proyectos</span
          >
        </div>

        <h1
          class="hero-title text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[6.5rem] font-bold text-white leading-[0.95] tracking-tight"
          aria-label="Allan Rosales"
        >
          <span class="hero-line inline-block">
            <span class="hero-char inline-block">A</span><span class="hero-char inline-block">l</span><span class="hero-char inline-block">l</span><span class="hero-char inline-block">a</span><span class="hero-char inline-block">n</span>
          </span>
          <br />
          <span class="hero-line inline-block">
            <span class="hero-char inline-block">R</span><span class="hero-char inline-block">o</span><span class="hero-char inline-block">s</span><span class="hero-char inline-block">a</span><span class="hero-char inline-block">l</span><span class="hero-char inline-block">e</span><span class="hero-char inline-block">s</span><span class="hero-char inline-block text-primary">.</span>
          </span>
        </h1>

        <p class="hero-description text-lg md:text-xl text-white/40 max-w-lg leading-relaxed">
          Ingeniero en Sistemas & Desarrollador Full-Stack. Diseño soluciones de
          software y arquitecturas digitales de alto impacto.
        </p>

        <div class="hero-actions flex flex-wrap gap-4 pt-2">
          <a
            href="#proyectos"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-secondary text-sm font-semibold rounded-full hover:bg-primary hover:text-white transition-all duration-300"
          >
            Ver Proyectos
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/docs/Curriculum Allan Rosales 26.docx.pdf"
            download
            class="inline-flex items-center gap-2 px-8 py-3.5 border border-white/15 text-white/70 text-sm font-semibold rounded-full hover:border-white/40 hover:text-white transition-all duration-300"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
            Descargar CV
          </a>
        </div>
      </div>

      <!-- Image -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <div class="hero-image relative">
          <div class="hero-glow absolute -inset-10 bg-primary/10 rounded-full blur-3xl">
          </div>
          <canvas
            id="hero-video-sequence"
            width="480"
            height="580"
            class="relative w-96 md:w-[28rem] lg:w-[34rem] h-auto object-contain"
            style="background-image: url('/img/allanani/AllanvVid_00000.webp'); background-size: cover; background-position: center;"
            aria-label="Allan Rosales — Ingeniero en Sistemas"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="border-t border-white/8">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
          stats.map((stat) => (
            <div class="hero-stat text-center md:text-left">
              <div class="text-3xl md:text-4xl font-bold text-white">
                {stat.value}
              </div>
              <div class="text-sm text-white/30 mt-1">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const totalFrames = 241;
  const fps = 20;
  const interval = 1000 / fps;
  let images: HTMLImageElement[] = new Array(totalFrames);
  let currentFrame = 0;
  let animationId: number | null = null;
  let lastTime = 0;
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let isPlaying = false;
  let imagesPreloaded = false;
  let heroIntroTween: gsap.core.Timeline | null = null;
  let heroGlowTween: gsap.core.Tween | null = null;
  let cleanupHeroTilt: (() => void) | null = null;

  function pad(num: number): string {
    return num.toString().padStart(5, "0");
  }

  function preloadImages() {
    if (imagesPreloaded) return;
    for (let i = 0; i < totalFrames; i++) {
      const img = new Image();
      img.src = "/img/allanani/AllanvVid_" + pad(i) + ".webp";
      images[i] = img;
    }
    imagesPreloaded = true;
  }

  function loopSequence(currentTime: number) {
    if (!lastTime) lastTime = currentTime;
    const delta = currentTime - lastTime;

    if (delta > interval) {
      const img = images[currentFrame];
      if (img && img.complete && img.naturalWidth > 0) {
        if (ctx && canvas) {
          if (canvas.style.backgroundImage) {
            canvas.style.backgroundImage = "";
          }
          if (canvas.width !== img.naturalWidth) {
            canvas.width = img.naturalWidth;
          }
          if (canvas.height !== img.naturalHeight) {
            canvas.height = img.naturalHeight;
          }
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
          currentFrame = (currentFrame + 1) % totalFrames;
        }
      }
      lastTime = currentTime - (delta % interval);
    }

    if (isPlaying) {
      animationId = requestAnimationFrame(loopSequence);
    }
  }

  function stopSequence() {
    isPlaying = false;
    if (animationId) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }
  }

  function initHeroAnimations() {
    const heroSection = document.getElementById("inicio");
    if (!heroSection) return;

    heroIntroTween?.kill();
    heroGlowTween?.kill();

    const animatedElements = [
      ".hero-badge",
      ".hero-description",
      ".hero-actions",
      ".hero-image",
    ];

    gsap.set(animatedElements, {
      autoAlpha: 0,
      y: 24,
      filter: "blur(8px)",
    });

    gsap.set(".hero-title", { autoAlpha: 1, y: 0, filter: "blur(0px)" });
    gsap.set(".hero-char", {
      clearProps: "opacity,transform,transformOrigin",
    });
    gsap.set(".hero-stat", { autoAlpha: 0, y: 20 });

    heroIntroTween = gsap
      .timeline({ defaults: { ease: "power3.out" } })
      .to(".hero-badge", {
        autoAlpha: 1,
        y: 0,
        filter: "blur(0px)",
        duration: 0.55,
      })
      .from(
        ".hero-char",
        {
          duration: 1,
          opacity: 0,
          scale: 0,
          y: 80,
          rotationX: 180,
          transformOrigin: "0% 50% -50",
          ease: "back.out(1.7)",
          stagger: 0.05,
        },
        "-=0.15",
      )
      .to(
        ".hero-description",
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.65,
        },
        "-=0.45",
      )
      .to(
        ".hero-actions",
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.55,
        },
        "-=0.4",
      )
      .to(
        ".hero-image",
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          scale: 1,
          duration: 0.85,
        },
        "<",
      )
      .to(
        ".hero-stat",
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.08,
        },
        "-=0.25",
      );

    heroGlowTween = gsap.to(".hero-glow", {
      scale: 1.07,
      duration: 2.8,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      transformOrigin: "50% 50%",
    });
  }

  function initHeroTilt() {
    cleanupHeroTilt?.();

    const canvasElement = document.getElementById("hero-video-sequence") as HTMLCanvasElement | null;
    if (!canvasElement) return;

    gsap.set(canvasElement, {
      transformPerspective: 900,
      transformOrigin: "50% 50%",
      willChange: "transform",
    });

    const rotateXTo = gsap.quickTo(canvasElement, "rotationX", {
      duration: 0.35,
      ease: "power3.out",
    });
    const rotateYTo = gsap.quickTo(canvasElement, "rotationY", {
      duration: 0.35,
      ease: "power3.out",
    });
    const zTo = gsap.quickTo(canvasElement, "z", {
      duration: 0.35,
      ease: "power3.out",
    });

    const maxTilt = 5;

    const onMouseMove = (event: MouseEvent) => {
      const rect = canvasElement.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width - 0.5;
      const y = (event.clientY - rect.top) / rect.height - 0.5;

      rotateYTo(x * (maxTilt * 2));
      rotateXTo(-y * (maxTilt * 2));
      zTo(10);
    };

    const onMouseLeave = () => {
      rotateXTo(0);
      rotateYTo(0);
      zTo(0);
    };

    canvasElement.addEventListener("mousemove", onMouseMove);
    canvasElement.addEventListener("mouseleave", onMouseLeave);

    cleanupHeroTilt = () => {
      canvasElement.removeEventListener("mousemove", onMouseMove);
      canvasElement.removeEventListener("mouseleave", onMouseLeave);
      gsap.set(canvasElement, {
        rotationX: 0,
        rotationY: 0,
        z: 0,
        willChange: "auto",
      });
    };
  }

  function cleanupHeroAnimations() {
    heroIntroTween?.kill();
    heroGlowTween?.kill();
    heroIntroTween = null;
    heroGlowTween = null;
    cleanupHeroTilt?.();
    cleanupHeroTilt = null;
  }

  function initSequence() {
    canvas = document.getElementById("hero-video-sequence") as HTMLCanvasElement | null;
    if (canvas) {
      ctx = canvas.getContext("2d");
      currentFrame = 0;
      lastTime = 0;
      isPlaying = true;

      preloadImages();

      if (animationId) cancelAnimationFrame(animationId);
      animationId = requestAnimationFrame(loopSequence);
    }

    initHeroAnimations();
    initHeroTilt();
  }

  // Init on each page load (including View Transition navigations)
  document.addEventListener("astro:page-load", initSequence);

  // Cleanup before page swap to prevent memory leaks
  document.addEventListener("astro:before-swap", () => {
    stopSequence();
    cleanupHeroAnimations();
  });
</script>
