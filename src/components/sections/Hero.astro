---
import StatItem from "../ui/StatItem.astro";

const stats = [
  { value: "+2", label: "Años de experiencia" },
  { value: "+20", label: "Proyectos realizados" },
  { value: "100%", label: "Compromiso" },
  { value: "100%", label: "Dedicación" },
];
---

<section id="inicio" class="relative bg-secondary overflow-hidden">
  <!-- Hero Content -->
  <div
    class="min-h-screen flex flex-col justify-center px-6 lg:px-10 max-w-[1400px] mx-auto pt-24 pb-16"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Text -->
      <div class="lg:col-span-7 space-y-8">
        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span
            class="text-xs font-medium text-white/50 uppercase tracking-widest"
            >Disponible para proyectos</span
          >
        </div>

        <h1
          class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[6.5rem] font-bold text-white leading-[0.95] tracking-tight"
        >
          Allan
          <br />
          Rosales<span class="text-primary">.</span>
        </h1>

        <p class="text-lg md:text-xl text-white/40 max-w-lg leading-relaxed">
          Ingeniero en Sistemas & Desarrollador Full-Stack. Diseño soluciones de
          software y arquitecturas digitales de alto impacto.
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href="#proyectos"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-secondary text-sm font-semibold rounded-full hover:bg-primary hover:text-white transition-all duration-300"
          >
            Ver Proyectos
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/docs/Curriculum Allan Rosales 26.docx.pdf"
            download
            class="inline-flex items-center gap-2 px-8 py-3.5 border border-white/15 text-white/70 text-sm font-semibold rounded-full hover:border-white/40 hover:text-white transition-all duration-300"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
            Descargar CV
          </a>
        </div>
      </div>

      <!-- Image -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <div class="relative">
          <div class="absolute -inset-10 bg-primary/10 rounded-full blur-3xl">
          </div>
          <canvas
            id="hero-video-sequence"
            width="480"
            height="580"
            class="relative w-96 md:w-[28rem] lg:w-[34rem] h-auto object-contain"
            style="background-image: url('/img/allanani/AllanvVid_00000.webp'); background-size: cover; background-position: center;"
            aria-label="Allan Rosales — Ingeniero en Sistemas"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="border-t border-white/8">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
          stats.map((stat) => (
            <div class="text-center md:text-left">
              <div class="text-3xl md:text-4xl font-bold text-white">
                {stat.value}
              </div>
              <div class="text-sm text-white/30 mt-1">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var totalFrames = 241;
    var images = new Array(totalFrames);
    var currentFrame = 0;
    var animationId = null;
    var lastTime = 0;
    var fps = 20;
    var interval = 1000 / fps;
    var canvas = null;
    var ctx = null;
    var isPlaying = false;

    function pad(num) {
      return num.toString().padStart(5, "0");
    }

    function preloadImages() {
      for (var i = 0; i < totalFrames; i++) {
        var img = new Image();
        img.src = "/img/allanani/AllanvVid_" + pad(i) + ".webp";
        images[i] = img;
      }
    }

    function loopSequence(currentTime) {
      if (!lastTime) lastTime = currentTime;
      var delta = currentTime - lastTime;

      if (delta > interval) {
        var img = images[currentFrame];
        if (img && img.complete && img.naturalWidth > 0) {
          if (ctx && canvas) {
            if (canvas.style.backgroundImage) {
              canvas.style.backgroundImage = "";
            }
            if (canvas.width !== img.naturalWidth) {
              canvas.width = img.naturalWidth;
            }
            if (canvas.height !== img.naturalHeight) {
              canvas.height = img.naturalHeight;
            }
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
            currentFrame = (currentFrame + 1) % totalFrames;
          }
        }
        lastTime = currentTime - (delta % interval);
      }

      if (isPlaying) {
        animationId = requestAnimationFrame(loopSequence);
      }
    }

    function initSequence() {
      canvas = document.getElementById("hero-video-sequence");
      if (canvas) {
        ctx = canvas.getContext("2d");
        currentFrame = 0;
        lastTime = 0;
        isPlaying = true;

        preloadImages();

        if (animationId) cancelAnimationFrame(animationId);
        animationId = requestAnimationFrame(loopSequence);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initSequence);
    } else {
      initSequence();
    }
  })();
</script>
