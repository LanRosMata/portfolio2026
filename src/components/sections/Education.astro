---
import SectionLabel from "../ui/SectionLabel.astro";

const certifications = [
  { title: "Desarrollo Web Completo (HTML5, CSS3, JS, PHP, MySQL)", issuer: "Udemy" },
  { title: "JavaScript Moderno — +20 Proyectos", issuer: "Udemy" },
  { title: "Astro y Headless WordPress", issuer: "Udemy" },
  { title: "Figma: Técnicas Avanzadas de Diseño", issuer: "Platzi" },
  { title: "Fundamentos de SEO", issuer: "Platzi" },
  { title: "Introducción al Desarrollo Backend", issuer: "Platzi" },
  { title: "Creación de Páginas Web con Astro", issuer: "Platzi" },
  { title: "Fundamentos de Bases de Datos (Oracle Academy)", issuer: "INFOP" },
  { title: "Conceptos Fundamentales de Java (Oracle Academy)", issuer: "INFOP" },
];
---

<section id="educacion" class="py-24 md:py-32 bg-secondary text-white relative overflow-hidden">
  <div class="ambient-layer" aria-hidden="true">
    <span class="ambient-blob ambient-primary ambient-top-right"></span>
    <span class="ambient-blob ambient-tertiary ambient-bottom-left ambient-delay-2"></span>
    <span class="ambient-blob ambient-soft ambient-mid-right ambient-delay-3"></span>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20">
      <!-- Left: Degree -->
      <div class="lg:col-span-5 space-y-8">
        <SectionLabel text="Educación" class="!border-white/10 !bg-white/5 !text-white/50" />
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight" data-reveal="up" data-reveal-start="top 70%">
          Formación
          <br />
          <span class="text-primary">académica.</span>
        </h2>
        
        <!-- Degree Card -->
        <div class="p-6 rounded-2xl border border-white/10 bg-white/5" data-reveal="up" data-reveal-delay="0.08" data-reveal-start="top 72%">
          <div class="flex items-start gap-4">
            <span class="text-4xl">🎓</span>
            <div>
              <h3 class="text-xl font-bold">Ingeniería en Sistemas</h3>
              <p class="text-white/40 text-sm mt-1">Universidad Politécnica de Honduras (UPH)</p>
              <span class="inline-block mt-3 text-xs font-semibold px-3 py-1 rounded-full bg-primary/15 text-primary">
                2009 — 2023
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Certifications (compact) -->
      <div class="lg:col-span-7 space-y-6">
        <div class="flex items-center justify-between" data-reveal="up" data-reveal-delay="0.12" data-reveal-start="top 72%">
          <h3 class="text-lg font-semibold text-white/70">Formación Continua</h3>
          <span class="text-xs text-white/30">{certifications.length} cursos</span>
        </div>
        
        <!-- Compact List -->
        <div class="space-y-px rounded-2xl overflow-hidden">
          {certifications.map((cert, i) => (
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 px-5 py-3.5 bg-white/[0.03] hover:bg-white/[0.06] transition-colors duration-300 group" data-reveal="up" data-reveal-delay={(i * 0.035).toFixed(2)} data-reveal-start="top 75%" data-reveal-start-mobile="top 92%">
              <div class="flex items-start gap-4 min-w-0 w-full sm:w-auto">
                <span class="text-xs font-mono text-white/20 w-5 shrink-0">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-sm font-medium text-white/70 group-hover:text-white transition-colors whitespace-normal break-words leading-snug">
                  {cert.title}
                </span>
              </div>
              <span class="text-xs font-medium text-white/25 shrink-0 self-end sm:self-auto">{cert.issuer}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
