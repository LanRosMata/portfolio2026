---
import SectionLabel from "./SectionLabel.astro";

const services = [
  {
    number: "01",
    title: "Desarrollo Web Full-Stack",
    description: "Aplicaciones web escalables con React, Astro, Node.js y bases de datos modernas. Desde el frontend hasta el deploy.",
    tags: ["React", "Astro", "Node.js", "TypeScript"],
  },
  {
    number: "02",
    title: "Arquitectura de Software",
    description: "Diseño de arquitecturas robustas, microservicios y sistemas distribuidos enfocados en rendimiento y escalabilidad.",
    tags: ["Microservicios", "API REST", "SSR/SSG"],
  },
  {
    number: "03",
    title: "Headless CMS & E-commerce",
    description: "Integración de Payload CMS, Strapi y plataformas de pago como Stripe para soluciones de contenido y comercio.",
    tags: ["Payload CMS", "Stripe", "PostgreSQL"],
  },
  {
    number: "04",
    title: "DevOps & Infraestructura",
    description: "Administración de VPS, contenedores Docker, pipelines CI/CD y despliegues automatizados en producción.",
    tags: ["Docker", "Linux", "CI/CD", "Coolify"],
  },
];
---

<section id="servicios" class="py-24 md:py-32 bg-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <SectionLabel text="Servicios" />
        <h2 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold text-secondary leading-[1.05] tracking-tight">
          Soluciones que
          <br />
          <span class="text-primary">transforman</span> negocios.
        </h2>
      </div>
      <p class="text-secondary/50 max-w-md text-base leading-relaxed">
        Combino ingeniería de software con diseño centrado en el usuario para crear 
        experiencias digitales que generan resultados reales.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-secondary/10 rounded-3xl overflow-hidden border border-secondary/10">
      {services.map((service) => (
        <div class="bg-white p-8 md:p-10 group hover:bg-neutral transition-colors duration-500">
          <div class="flex items-start justify-between mb-6">
            <span class="text-5xl font-bold text-secondary/5 group-hover:text-primary/10 transition-colors duration-500">
              {service.number}
            </span>
            <svg class="w-5 h-5 text-secondary/20 group-hover:text-primary transition-all duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-secondary mb-3">{service.title}</h3>
          <p class="text-sm text-secondary/50 leading-relaxed mb-5">{service.description}</p>
          <div class="flex flex-wrap gap-2">
            {service.tags.map((tag) => (
              <span class="text-[11px] font-medium px-3 py-1 rounded-full bg-secondary/5 text-secondary/50">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
