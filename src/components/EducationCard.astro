---
interface Props {
  degree: string;
  institution: string;
  year?: string;
  icon?: string;
  class?: string;
}

const { degree, institution, year, icon = "🎓", class: className } = Astro.props;
---

<div
  class:list={[
    "glass-card rounded-2xl p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1",
    className,
  ]}
>
  <div class="flex items-start gap-4">
    <div
      class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-2xl shrink-0"
    >
      {icon}
    </div>
    <div>
      <h3 class="text-lg font-bold text-secondary mb-1">{degree}</h3>
      <p class="text-sm text-secondary/60">{institution}</p>
      {year && <span class="text-xs text-primary font-semibold mt-2 inline-block">{year}</span>}
    </div>
  </div>
</div>
