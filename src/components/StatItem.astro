---
interface Props {
  value: string;
  label: string;
  class?: string;
}

const { value, label, class: className } = Astro.props;
---

<div class:list={["text-center", className]}>
  <div class="text-3xl md:text-4xl font-bold text-secondary">{value}</div>
  <div class="text-sm text-secondary/50 mt-1 font-medium">{label}</div>
</div>
