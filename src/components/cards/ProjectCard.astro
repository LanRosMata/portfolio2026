---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  tags?: string[];
  href?: string;
  class?: string;
  variant?: "large" | "small";
}

const {
  title,
  description,
  imageSrc,
  tags = [],
  href = "#",
  class: className,
  variant = "small",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "group block glass-card rounded-3xl overflow-hidden transition-all duration-500 hover:shadow-xl hover:-translate-y-2",
    variant === "large" ? "md:col-span-2" : "",
    className,
  ]}
>
  <div
    class:list={[
      "overflow-hidden",
      variant === "large" ? "h-56 md:h-72" : "h-48",
    ]}
  >
    <Image
      src={imageSrc}
      alt={title}
      width={800}
      height={500}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
  </div>
  <div class="p-6">
    <h3
      class:list={[
        "font-bold text-secondary mb-2",
        variant === "large" ? "text-xl md:text-2xl" : "text-lg",
      ]}
    >
      {title}
    </h3>
    <p class="text-sm text-secondary/60 leading-relaxed mb-4">{description}</p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-neutral text-secondary/70">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
