---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  icon?: string;
  imageSrc?: ImageMetadata;
  class?: string;
}

const { title, description, icon, imageSrc, class: className } = Astro.props;
---

<div
  class:list={[
    "glass-card rounded-2xl p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 group",
    className,
  ]}
>
  {
    imageSrc && (
      <div class="mb-4 overflow-hidden rounded-xl">
        <Image
          src={imageSrc}
          alt={title}
          width={400}
          height={250}
          class="w-full h-40 object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }
  {
    icon && (
      <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 text-2xl">
        <span>{icon}</span>
      </div>
    )
  }
  <h3 class="text-lg font-bold text-secondary mb-2">{title}</h3>
  <p class="text-sm text-secondary/60 leading-relaxed">{description}</p>
</div>
