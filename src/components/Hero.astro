---
import { Image } from "astro:assets";
import StatItem from "./StatItem.astro";

const heroImage = (await import("../assets/AllanRosales.jpg")).default;

const stats = [
  { value: "+5", label: "Años de experiencia" },
  { value: "+20", label: "Proyectos entregados" },
  { value: "+15", label: "Clientes satisfechos" },
  { value: "100%", label: "Dedicación" },
];
---

<section id="inicio" class="relative bg-secondary overflow-hidden">
  <!-- Hero Content -->
  <div class="min-h-screen flex flex-col justify-center px-6 lg:px-10 max-w-[1400px] mx-auto pt-24 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Text -->
      <div class="lg:col-span-7 space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span class="text-xs font-medium text-white/50 uppercase tracking-widest">Disponible para proyectos</span>
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[6.5rem] font-bold text-white leading-[0.95] tracking-tight">
          Allan
          <br />
          Rosales<span class="text-primary">.</span>
        </h1>

        <p class="text-lg md:text-xl text-white/40 max-w-lg leading-relaxed">
          Ingeniero en Sistemas & Desarrollador Full-Stack.
          Diseño soluciones de software y arquitecturas digitales
          de alto impacto.
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href="#proyectos"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-secondary text-sm font-semibold rounded-full hover:bg-primary hover:text-white transition-all duration-300"
          >
            Ver Proyectos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/docs/Curriculum Allan Rosales 26.docx.pdf"
            download
            class="inline-flex items-center gap-2 px-8 py-3.5 border border-white/15 text-white/70 text-sm font-semibold rounded-full hover:border-white/40 hover:text-white transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            Descargar CV
          </a>
        </div>
      </div>

      <!-- Image -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <div class="relative">
          <div class="absolute -inset-8 bg-gradient-to-tr from-primary/15 via-transparent to-white/5 rounded-[2.5rem] blur-3xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/10">
            <Image
              src={heroImage}
              alt="Allan Rosales — Ingeniero en Sistemas"
              width={480}
              height={580}
              class="w-64 md:w-72 lg:w-[22rem] h-auto object-cover"
              loading="eager"
            />
            <!-- Glass overlay at bottom -->
            <div class="absolute bottom-0 inset-x-0 p-5 bg-gradient-to-t from-black/80 via-black/40 to-transparent">
              <p class="text-white font-bold text-lg">Ingeniero en Sistemas</p>
              <p class="text-white/50 text-sm">Tegucigalpa, Honduras</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="border-t border-white/8">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center md:text-left">
            <div class="text-3xl md:text-4xl font-bold text-white">{stat.value}</div>
            <div class="text-sm text-white/30 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
