---
interface Props {
  name: string;
  icon: string;
  class?: string;
}

const { name, icon, class: className } = Astro.props;
---

<div
  class:list={[
    "flex flex-col items-center gap-3 p-4 rounded-2xl transition-all duration-300 hover:bg-white/60 hover:shadow-md group cursor-default",
    className,
  ]}
>
  <span
    class="text-4xl transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-1"
    >{icon}</span
  >
  <span class="text-xs font-medium text-secondary/60 group-hover:text-secondary transition-colors"
    >{name}</span
  >
</div>
