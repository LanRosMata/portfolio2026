---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import ScrollToTop from "../components/common/ScrollToTop.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title = "Allan Rosales — Ingeniero en Sistemas",
  description = "Portfolio profesional de Allan Rosales. Ingeniero en Sistemas especializado en arquitectura de software, desarrollo web y soluciones digitales de alto impacto.",
  image = "/image/AllanRosales.jpg",
  keywords = "Allan Rosales, Ingeniero en Sistemas, Desarrollo web, Arquitectura de software, Portfolio",
} = Astro.props;

// Construye URLs absolutas para Open Graph y Twitter
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const socialImageURL = new URL(image, Astro.site || Astro.url);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter / X -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="font-sans antialiased text-secondary bg-white">
    <slot />
    <ScrollToTop />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  /* Lenis required styles */
  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }
</style>

<script>
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  let lenis: Lenis | null = null;
  let cleanupScrollReveals: (() => void) | null = null;

  gsap.registerPlugin(ScrollTrigger);

  function initLenis() {
    // Destroy previous instance if exists
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }

    lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });

    function raf(time: number) {
      lenis!.raf(time);
      requestAnimationFrame(raf);
    }

    requestAnimationFrame(raf);
  }

  function initScrollReveals() {
    cleanupScrollReveals?.();

    const triggers: ScrollTrigger[] = [];
    const animations: gsap.core.Tween[] = [];

    const revealElements = document.querySelectorAll<HTMLElement>("[data-reveal]");
    const isMobile = window.matchMedia("(max-width: 767px)").matches;

    revealElements.forEach((element) => {
      if (isMobile && element.dataset.revealMobile === "off") {
        gsap.set(element, {
          autoAlpha: 1,
          x: 0,
          y: 0,
          scale: 1,
          clearProps: "transform,opacity,visibility",
        });
        return;
      }

      const revealType = element.dataset.reveal || "up";
      const delay = Number.parseFloat(element.dataset.revealDelay || "0");
      const start = isMobile
        ? element.dataset.revealStartMobile || element.dataset.revealStart || "top 50%"
        : element.dataset.revealStart || "top 50%";

      const fromVars: gsap.TweenVars = {
        autoAlpha: 0,
        y: 24,
      };

      if (revealType === "left") {
        fromVars.x = -28;
        fromVars.y = 0;
      } else if (revealType === "right") {
        fromVars.x = 28;
        fromVars.y = 0;
      } else if (revealType === "scale") {
        fromVars.scale = 0.96;
      }

      gsap.set(element, fromVars);

      const tween = gsap.to(element, {
        autoAlpha: 1,
        x: 0,
        y: 0,
        scale: 1,
        duration: 0.65,
        delay,
        ease: "power2.out",
        clearProps: "transform,opacity,visibility",
        scrollTrigger: {
          trigger: element,
          start,
          once: true,
        },
      });

      animations.push(tween);
      if (tween.scrollTrigger) {
        triggers.push(tween.scrollTrigger);
      }
    });

    cleanupScrollReveals = () => {
      animations.forEach((animation) => animation.kill());
      triggers.forEach((trigger) => trigger.kill());
      cleanupScrollReveals = null;
    };

    ScrollTrigger.refresh();
    requestAnimationFrame(() => ScrollTrigger.refresh());
  }

  function initPageEffects() {
    initLenis();
    initScrollReveals();
  }

  // Init on first load and on each page navigation (View Transitions)
  document.addEventListener("astro:page-load", initPageEffects);

  // Cleanup before page swap to prevent memory leaks
  document.addEventListener("astro:before-swap", () => {
    cleanupScrollReveals?.();
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }
  });
</script>
