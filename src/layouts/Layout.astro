---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Allan Rosales — Ingeniero en Sistemas",
  description = "Portfolio profesional de Allan Rosales. Ingeniero en Sistemas especializado en arquitectura de software, desarrollo web y soluciones digitales de alto impacto.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased text-secondary bg-white">
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
