---
import Footer from "../components/common/Footer.astro";
import Navbar from "../components/common/Navbar.astro";
import ProjectHero from "../components/sections/ProjectHero.astro";
import Layout from "./Layout.astro";

// MDX layouts receive frontmatter via Astro.props.frontmatter
const frontmatter = (Astro.props as any).frontmatter ?? Astro.props;

const {
  title = "Proyecto",
  description,
  image,
  keywords,
  subtitle,
  tags,
  year,
  role,
  client,
  heroImage,
  accentColor,
  liveUrl,
  repoUrl,
} = frontmatter;

// ── Resolve co-located images ──
// Eagerly import all images under project directories so we can resolve
// relative frontmatter paths like "./img/hero.png" at build time.
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/pages/proyectos/**/*.{png,jpg,jpeg,webp,gif,svg,avif}",
  { eager: true },
);

let resolvedHeroImage: string | undefined = heroImage;

if (heroImage?.startsWith("./")) {
  // Current page URL path, e.g. "/proyectos/deliciasca/"
  const pagePath = Astro.url.pathname.replace(/\/$/, "");
  const relPath = heroImage.slice(2); // strip "./"
  const globKey = `/src/pages${pagePath}/${relPath}`;

  const match = projectImages[globKey];
  if (match) {
    // .src is the optimized/hashed URL generated by Vite
    resolvedHeroImage = match.default.src;
  }
}

const pageTitle = `${title} — Allan Rosales`;
---

<Layout title={pageTitle} description={description} image={image} keywords={keywords}>
  <Navbar
    navItems={[
      { label: "Inicio", href: "/" },
    ]}
  />

  <!-- Project Hero -->
  <ProjectHero
    title={title}
    subtitle={subtitle}
    tags={tags}
    year={year}
    role={role}
    client={client}
    heroImage={resolvedHeroImage}
    accentColor={accentColor}
    liveUrl={liveUrl}
    repoUrl={repoUrl}
  />

  <!-- Project Content -->
  <main class="project-content-area">
    <article class="project-article">
      <slot />
    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Content area ── */
  .project-content-area {
    background-color: var(--color-neutral, #f5f5f7);
    position: relative;
    z-index: 1;
  }

  /* ── Article container ── */
  .project-article {
    max-width: 820px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  @media (min-width: 768px) {
    .project-article {
      padding: 5rem 2rem 8rem;
    }
  }

  @media (min-width: 1024px) {
    .project-article {
      padding: 6rem 2.5rem 10rem;
    }
  }

  /* ── Prose styles for MDX content ── */

  /* Headings */
  .project-article :global(h1) {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
  }

  .project-article :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(10, 10, 10, 0.06);
  }

  .project-article :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-secondary);
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .project-article :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  /* Paragraphs */
  .project-article :global(p) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(10, 10, 10, 0.65);
    margin-bottom: 1.5rem;
  }

  /* Links */
  .project-article :global(a) {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    transition: all 0.2s ease;
  }

  .project-article :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  /* Bold / Strong */
  .project-article :global(strong) {
    font-weight: 600;
    color: var(--color-secondary);
  }

  /* Lists */
  .project-article :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }

  .project-article :global(ul li) {
    position: relative;
    padding-left: 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(10, 10, 10, 0.65);
    margin-bottom: 0.5rem;
  }

  .project-article :global(ul li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .project-article :global(ol) {
    padding-left: 1.75rem;
    margin-bottom: 1.5rem;
    counter-reset: ol-counter;
    list-style: none;
  }

  .project-article :global(ol li) {
    position: relative;
    padding-left: 1rem;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(10, 10, 10, 0.65);
    margin-bottom: 0.5rem;
    counter-increment: ol-counter;
  }

  .project-article :global(ol li::before) {
    content: counter(ol-counter) ".";
    position: absolute;
    left: -1rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Images */
  .project-article :global(img) {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 2rem 0;
    border: 1px solid rgba(10, 10, 10, 0.06);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.06);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-article :global(img:hover) {
    transform: scale(1.01);
  }

  /* Blockquote */
  .project-article :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--color-primary);
    background: rgba(10, 10, 10, 0.02);
    border-radius: 0 0.75rem 0.75rem 0;
  }

  .project-article :global(blockquote p) {
    font-size: 1.0625rem;
    font-style: italic;
    color: rgba(10, 10, 10, 0.55);
    margin-bottom: 0;
  }

  /* Code */
  .project-article :global(code) {
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 0.875rem;
    background: rgba(10, 10, 10, 0.05);
    padding: 0.2em 0.45em;
    border-radius: 0.375rem;
    color: var(--color-secondary);
  }

  .project-article :global(pre) {
    margin: 2rem 0;
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--color-secondary) !important;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
  }

  .project-article :global(pre code) {
    background: none;
    padding: 0;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  /* Horizontal Rule */
  .project-article :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(10, 10, 10, 0.08) 30%,
      rgba(10, 10, 10, 0.08) 70%,
      transparent
    );
    margin: 3rem 0;
  }

  /* Tables */
  .project-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
  }

  .project-article :global(th) {
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: var(--color-secondary);
    border-bottom: 2px solid rgba(10, 10, 10, 0.08);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-article :global(td) {
    padding: 0.75rem 1rem;
    color: rgba(10, 10, 10, 0.6);
    border-bottom: 1px solid rgba(10, 10, 10, 0.04);
  }

  .project-article :global(tr:hover td) {
    background: rgba(10, 10, 10, 0.02);
  }

  /* First heading in content — reduce top margin since hero already exists */
  .project-article :global(:first-child) {
    margin-top: 0;
  }
</style>
